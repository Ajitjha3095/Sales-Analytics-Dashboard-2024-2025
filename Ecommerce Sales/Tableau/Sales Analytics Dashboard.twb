      <aliases enabled='yes' />
      <column caption='MarkP&amp;L' datatype='string' name='[Calculation_0084399721287681]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF  ISNULL([Calculation_0400234095357961]) then &apos;gray&apos;&#13;&#10;ELSEIF [Calculation_0400234095357961]&lt;0 then &apos;pink&apos;&#13;&#10;ELSEIF [Calculation_0400234095357961]&gt;0 then &apos;teal&apos;&#13;&#10;END' />
      </column>
      <column caption='Total order' datatype='integer' name='[Calculation_0230635472347136]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Order_ID])' />
      </column>
      <column caption='Current Year Sales' datatype='integer' name='[Calculation_0400234080985088]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order_Date]) = [Parameters].[Parameter 1] THEN [Total_Sales]&#13;&#10;END' />
      </column>
      <column caption='YoY Growth %' datatype='real' name='[Calculation_0400234084630531]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(([Calculation_0400234080985088] -[Calculation_0406006178922496])/[Calculation_0406006178922496])' />
      </column>
      <column caption='Calculation1' datatype='real' default-format='p0.00%' name='[Calculation_0400234085814276]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF LOOKUP(ZN(SUM([Total_Sales])), -1) = 0 OR &#13;&#10;   ISNULL(LOOKUP(SUM([Total_Sales]), -1))&#13;&#10;THEN NULL&#13;&#10;ELSE &#13;&#10;  (ZN(SUM([Total_Sales])) - LOOKUP(ZN(SUM([Total_Sales])), -1))&#13;&#10;  / ABS(LOOKUP(ZN(SUM([Total_Sales])), -1))&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sales LY' datatype='integer' name='[Calculation_0400234091376647]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOOKUP(SUM([Total_Sales]), -1)'>
          <table-calc level-address='[federated.1s8qpuo034p2hb1abfxk10uzmglk].[yr:Order_Date:ok]' ordering-field='[federated.1s8qpuo034p2hb1abfxk10uzmglk].[Order_Date]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='Sales YoY %' datatype='real' default-format='p0.00%' name='[Calculation_0400234091462664]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([Calculation_0400234091376647]) OR [Calculation_0400234091376647] = 0&#13;&#10; THEN NULL&#13;&#10; ELSE&#13;&#10;  (SUM([Total_Sales]) - [Calculation_0400234091376647]) / ABS([Calculation_0400234091376647])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='VS Last Year %' datatype='real' datatype-customized='true' default-format='*0.00%, -0.00%' name='[Calculation_0400234095357961]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='(SUM([Calculation_0400234080985088])- SUM([Calculation_0406006178922496])) / SUM([Calculation_0406006178922496])' />
      </column>
      <column caption='Oder date (year)' datatype='integer' name='[Calculation_0400234102267914]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([Order_Date])' />
      </column>
      <column caption='Previous Year Sales' datatype='integer' name='[Calculation_0406006178922496]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF YEAR([Order_Date]) = [Parameters].[Parameter 1]-1 THEN [Total_Sales]&#13;&#10;END' />
      </column>
